  "_section_business_rules": "Ageas-specific business rules",
  "business_rules": {
    "domain_rules": {
      "claims": {
        "rules": [
          {"rule_id": "CLM-001", "rule": "Multi-subcluster jobs must transition as atomic units", "rationale": "Ensure data consistency across claims processing"},
          {"rule_id": "CLM-002", "rule": "NR34/NR35/NR36 regulatory compliance required", "rationale": "Belgian insurance regulatory requirements"},
          {"rule_id": "CLM-003", "rule": "DC Claims is the future core platform", "rationale": "Qualifies for Strategic approach"},
          {"rule_id": "CLM-004", "rule": "CCS-dependent clusters must complete by Q3 2026", "rationale": "CCS decommissioning deadline"}
        ],
        "structure": {"job_count": 163, "subclusters": 7, "notes": "Atomic unit is the claims processing chain"}
      },
      "entities": {
        "rules": [
          {"rule_id": "ENT-001", "rule": "No life/non-life split for entities", "rationale": "Unified entity master across all business lines"},
          {"rule_id": "ENT-002", "rule": "EDM is the future core master", "rationale": "Qualifies for Strategic approach"},
          {"rule_id": "ENT-003", "rule": "Entity Dimensions is foundational", "rationale": "Must complete before other entity clusters"},
          {"rule_id": "ENT-004", "rule": "Cross-domain entity references must align", "rationale": "Entities serve Claims and Policies"}
        ],
        "structure": {"job_count": 377, "subclusters": 10, "notes": "No business line segmentation"}
      },
      "policies": {
        "rules": [
          {"rule_id": "POL-001", "rule": "Life/Non-Life split required", "rationale": "Different regulatory and product structures"},
          {"rule_id": "POL-002", "rule": "Policy Core is foundational", "rationale": "Must complete before product-specific clusters"},
          {"rule_id": "POL-003", "rule": "Polaris is the future core platform", "rationale": "Qualifies for Strategic approach"},
          {"rule_id": "POL-004", "rule": "Tecnisys clusters → Q3 2028 deadline", "rationale": "Source system decommissioning"},
          {"rule_id": "POL-005", "rule": "Cogen clusters → Q3 2028 deadline", "rationale": "Source system decommissioning"}
        ],
        "structure": {"job_count": 775, "subclusters": 25, "notes": "Life vs Non-Life segmentation; multiple legacy sources"}
      }
    },
    "regulatory_compliance": {
      "NR34": {"description": "Belgian insurance regulatory requirement for claims"},
      "NR35": {"description": "Belgian insurance regulatory requirement for claims"},
      "NR36": {"description": "Belgian insurance regulatory requirement for claims"}
    },
    "analytical_models": {
      "_note": "Used for Bridge-to-Model approach",
      "models": ["UNO", "MAOC", "MAE", "MAS"]
    }
  },

